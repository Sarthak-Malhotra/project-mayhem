# Neon Postgres URLs
DATABASE_URL="postgresql://[user]:[password]@[neon_hostname]-pooler.[region].aws.neon.tech/[dbname]?sslmode=require"
DIRECT_DATABASE_URL="postgresql://[user]:[password]@[neon_hostname].[region].aws.neon.tech/[dbname]?sslmode=require"

# Keep answer values server-only. Use the exact normalized puzzle answer value for each key.
PUZZLE_OPERATION_DEADLIGHT_QUARANTINE_REGISTRATION="your_quarantine_registration_answer_here"
PUZZLE_OPERATION_DEADLIGHT_BEHAVIORAL_MATCH="your_behavioral_match_answer_here"
PUZZLE_OPERATION_DEADLIGHT_BLACK_SYMBOL="your_black_symbol_answer_here"
PUZZLE_OPERATION_DEADLIGHT_IDENTITY_DISTORTION="your_identity_distortion_answer_here"
PUZZLE_OPERATION_DEADLIGHT_MEMORY_CORRUPTION="your_memory_corruption_answer_here"
PUZZLE_OPERATION_DEADLIGHT_FINAL_TRANSMISSION="your_final_transmission_answer_here"

# Admin bypass override code
ADMIN_OVERRIDE_CODE="your_admin_override_code_here"

# Session Cookie HMAC Signature Secret (required for security)
SESSION_SECRET="your_session_cookie_signature_secret_here"

# Brevo Email Integration
# Retrieve API Key from your Brevo Dashboard (e.g., xkeysib-...)
BREVO_API_KEY=""
# For unverified domains, you must verify your sender email in Brevo.
EMAIL_FROM="PROJECT NULL <onboarding@brevo.com>"

# Firebase Configuration
NEXT_PUBLIC_FIREBASE_API_KEY="your_firebase_api_key_here"
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="your_firebase_auth_domain_here"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="your_firebase_project_id_here"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="your_firebase_storage_bucket_here"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="your_firebase_messaging_sender_id_here"
NEXT_PUBLIC_FIREBASE_APP_ID="your_firebase_app_id_here"
NEXT_PUBLIC_FIREBASE_FIRESTORE_DB_ID="your_firebase_firestore_db_id_here"
